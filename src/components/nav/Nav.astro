---
const {
  variant = "default", // "default" | "overlay"
} = Astro.props;

const links = [
  { href: "/missao", label: "Sobre" },
  { href: "/areas-de-atuacao", label: "Áreas de Atuação" },
  { href: "/programas-e-projetos", label: "Programas e Projetos" },
  { href: "/servicos", label: "Prestação de Serviços" },
  { href: "/realizacoes", label: "Realizações" },
  { href: "/loja", label: "Loja" },
];

const base = "z-40 w-full";

const styles =
  variant === "overlay"
    ? "absolute top-0 left-0 right-0 bg-white/90 backdrop-blur"
    : "sticky top-0 bg-white/90 shadow-sm backdrop-blur";
---

<header class={`${base} ${styles}`}>
  <!--
    Mobile layout  (< md):
      - Fixed height ~66px via py-2 (approx 16px top+bottom) + 50px logo = ~66px
      - Relative container so the centered logo can use absolute centering
      - Hamburger pinned to the right with ml-auto
    Desktop layout (md+):
      - flex, justify-between: logo left | nav center | Apoie right
  -->
  <div class="relative mx-auto flex max-w-6xl items-center px-4 py-2 md:justify-between md:py-3">

    <!-- ── MOBILE: round logo centered absolutely ── -->
    <a
      href="/"
      class="absolute left-1/2 -translate-x-1/2 md:hidden"
      aria-label="Início"
    >
      <img
        src="/brand/logo-round.png"
        alt="OAMa"
        class="h-[50px] w-[50px] rounded-full object-cover"
      />
    </a>

    <!-- ── DESKTOP: SVG logo, left-aligned ── -->
    <a href="/" class="hidden md:flex items-center gap-2" aria-label="Início">
      <img src="/logo-oama.svg" alt="OAMa" class="h-9 w-auto" />
    </a>

    <!-- ── DESKTOP nav: center ── -->
    <nav class="hidden items-center gap-6 text-xs font-semibold text-oama-ink/80 md:flex">
      {
        links.map((link) => (
          <a
            href={link.href}
            class="border-b-2 border-transparent pb-1 transition hover:border-oama-yellow hover:text-oama-ink"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <!-- ── DESKTOP "Apoie" CTA (hidden on mobile) ── -->
    <a
      href="/apoie"
      class="hidden md:inline-flex rounded-full bg-oama-yellow px-4 py-2 text-xs font-extrabold uppercase tracking-[0.12em] text-oama-ink shadow-sm hover:brightness-95"
    >
      Apoie
    </a>

    <!-- ── MOBILE: spacer so hamburger aligns right (logo is absolute) ── -->
    <span class="flex-1 md:hidden" aria-hidden="true"></span>

    <!-- ── MOBILE: hamburger button (hidden on desktop) ── -->
    <button
      id="mobile-menu-toggle"
      class="md:hidden flex flex-col justify-center items-center gap-1.5 p-1 focus:outline-none"
      aria-label="Abrir menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span class="block w-6 h-0.5 bg-oama-ink"></span>
      <span class="block w-6 h-0.5 bg-oama-ink"></span>
      <span class="block w-6 h-0.5 bg-oama-ink"></span>
    </button>

  </div>
</header>

<!-- ── Mobile fullscreen menu overlay ── -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 flex flex-col bg-white transform -translate-y-full transition-transform duration-300 ease-in-out md:hidden"
  aria-hidden="true"
>
  <!-- Menu header: round logo left, X close button right -->
  <div class="flex items-center justify-between px-4 py-2 border-b border-oama-ink/10" style="min-height: 66px;">
    <a href="/" aria-label="Início">
      <img
        src="/brand/logo-round.png"
        alt="OAMa"
        class="h-[50px] w-[50px] rounded-full object-cover"
      />
    </a>
    <button
      id="mobile-menu-close"
      class="flex flex-col justify-center items-center gap-1.5 p-1 focus:outline-none"
      aria-label="Fechar menu"
    >
      <!-- X icon: two rotated bars -->
      <span class="block w-6 h-0.5 bg-oama-ink rotate-45 translate-y-[0.375rem]"></span>
      <span class="block w-6 h-0.5 bg-oama-ink -rotate-45 -translate-y-[0.375rem]"></span>
    </button>
  </div>

  <!-- Nav links: vertically stacked, large Montserrat SemiBold, centered -->
  <nav class="flex flex-col flex-1 justify-center items-center gap-8 px-8">
    {
      links.map((link) => (
        <a
          href={link.href}
          class="text-[18px] font-semibold text-[#1e1702] hover:text-oama-yellow transition-colors duration-150 text-center"
          style="font-family: 'Montserrat', sans-serif;"
        >
          {link.label}
        </a>
      ))
    }
  </nav>

  <!-- "Apoie" CTA pinned at bottom -->
  <div class="px-8 pb-12">
    <a
      href="/apoie"
      class="block w-full text-center rounded-full bg-oama-yellow px-4 py-3 text-sm font-extrabold uppercase tracking-[0.12em] text-oama-ink shadow-sm hover:brightness-95"
    >
      Apoie
    </a>
  </div>
</div>

<script>
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const closeBtn = document.getElementById("mobile-menu-close");

  function openMenu() {
    if (!menu || !toggle) return;
    menu.classList.remove("-translate-y-full");
    menu.classList.add("translate-y-0");
    menu.setAttribute("aria-hidden", "false");
    toggle.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  }

  function closeMenu() {
    if (!menu || !toggle) return;
    menu.classList.remove("translate-y-0");
    menu.classList.add("-translate-y-full");
    menu.setAttribute("aria-hidden", "true");
    toggle.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  }

  toggle?.addEventListener("click", () => {
    const isOpen = menu?.getAttribute("aria-hidden") === "false";
    isOpen ? closeMenu() : openMenu();
  });

  closeBtn?.addEventListener("click", closeMenu);

  // Close on Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeMenu();
  });

  // Close when a nav link inside the menu is clicked
  menu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMenu);
  });
</script>
