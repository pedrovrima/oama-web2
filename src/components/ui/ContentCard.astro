---
interface Props {
  image: string;
  imageAlt?: string;
  label: string;
  title: string;
  href?: string;
}

const { image, imageAlt = "", label, title, href = "#" } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-[20px] bg-white shadow-md hover:shadow-lg transition-shadow duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-oama-yellow"
>
  <!-- Image: 239px wide × 236px tall → aspect-[239/236] (card is 239×408 total) -->
  <div class="aspect-[239/236] w-full overflow-hidden">
    <img
      src={image}
      alt={imageAlt || title}
      loading="lazy"
      class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
    />
  </div>

  <!-- Text area: 172px (408 - 236) — pt 20px, pb 77px -->
  <div class="flex flex-col gap-0 px-[23px] pt-5 pb-[77px]">
    <span class="text-base font-semibold leading-[25px] text-oama-ink font-montserrat">
      {label}
    </span>
    <p class="text-base font-normal leading-[25px] text-oama-ink font-montserrat line-clamp-2">
      {title}
    </p>
  </div>
</a>
